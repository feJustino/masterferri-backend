{
  "name": "masterferri-backend",
  "version": "1.0.0",
  "description": "Backend Node.js com Express para integração com API do Bling",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docker:dev": "docker-compose up -d",
    "docker:build": "docker build -t masterferri-backend .",
    "swagger": "swagger-jsdoc -d swaggerDef.js -o swagger.json src/controllers/*.ts"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "bling",
    "api",
    "oauth2",
    "solid"
  ],
  "author": "MasterFerri",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "compression": "^1.8.1",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.21.2",
    "express-rate-limit": "6.10.0",
    "firebase-admin": "^13.5.0",
    "helmet": "7.0.0",
    "node-cache": "5.1.2",
    "pino": "8.15.0",
    "pino-http": "8.5.0",
    "pino-pretty": "10.2.0",
    "reflect-metadata": "0.1.13",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.0",
    "tsyringe": "4.8.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/compression": "1.7.3",
    "@types/cors": "2.8.14",
    "@types/express": "4.17.17",
    "@types/jest": "29.5.5",
    "@types/node": "20.6.0",
    "@types/supertest": "2.0.12",
    "@types/swagger-jsdoc": "6.0.1",
    "@types/swagger-ui-express": "4.1.4",
    "@typescript-eslint/eslint-plugin": "6.7.0",
    "@typescript-eslint/parser": "6.7.0",
    "eslint": "8.49.0",
    "jest": "29.7.0",
    "nodemon": "3.0.1",
    "supertest": "6.3.3",
    "ts-jest": "29.1.1",
    "tsx": "4.20.5",
    "typescript": "5.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
